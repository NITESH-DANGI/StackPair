# ── StackPair M-01 Auth Environment Variables ───────────
# Copy this file to .env and fill in your values.

# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# JWT (Supabase JWT secret — find in Supabase dashboard → Settings → API)
JWT_SECRET=your-supabase-jwt-secret

# Database (Supabase Postgres direct connection, asyncpg format)
DATABASE_URL=postgresql+asyncpg://postgres.xxx:password@db.xxx.supabase.co:5432/postgres

# Redis (Upstash)
UPSTASH_REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Google OAuth
GOOGLE_REDIRECT_URI=https://stackpair.app/auth/google/callback

# Internal Service Auth (M-02 verification service)
INTERNAL_SERVICE_TOKEN=generate-a-long-random-secret-here

# Email (Resend — used by Supabase for OTP delivery)
RESEND_API_KEY=re_xxx
